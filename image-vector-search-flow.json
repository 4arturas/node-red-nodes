[
    {
        "id": "image_search_tab",
        "type": "tab",
        "label": "Image Vector Search",
        "disabled": false,
        "info": "This flow demonstrates Image Vector Search using CLIP embeddings and SQLite-vec."
    },
    {
        "id": "init_db",
        "type": "inject",
        "z": "image_search_tab",
        "name": "Initialize DB",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "CREATE VIRTUAL TABLE IF NOT EXISTS image_embeddings USING vec0(id INTEGER PRIMARY KEY, embedding FLOAT[512], filename TEXT);",
        "x": 130,
        "y": 80,
        "wires": [
            [
                "sqlite_init"
            ]
        ]
    },
    {
        "id": "sqlite_init",
        "type": "sqlite-vec",
        "z": "image_search_tab",
        "name": "SQLite Init",
        "dbPath": "images_vector.db",
        "operation": "execute",
        "sql": "",
        "x": 330,
        "y": 80,
        "wires": [
            [
                "debug_results"
            ]
        ]
    },
    {
        "id": "index_cat",
        "type": "inject",
        "z": "image_search_tab",
        "name": "Index Cat",
        "props": [
            {
                "p": "filename",
                "v": "cat.png",
                "vt": "str"
            },
            {
                "p": "filepath",
                "v": "c:\\Users\\4artu\\IdeaProjects\\node-red-nodes\\tutorial_images\\cat.png",
                "vt": "str"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "x": 110,
        "y": 160,
        "wires": [
            [
                "read_image"
            ]
        ]
    },
    {
        "id": "index_dog",
        "type": "inject",
        "z": "image_search_tab",
        "name": "Index Dog",
        "props": [
            {
                "p": "filename",
                "v": "dog.png",
                "vt": "str"
            },
            {
                "p": "filepath",
                "v": "c:\\Users\\4artu\\IdeaProjects\\node-red-nodes\\tutorial_images\\dog.png",
                "vt": "str"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "x": 110,
        "y": 200,
        "wires": [
