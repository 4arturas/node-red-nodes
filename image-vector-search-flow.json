        "props": [
            {
                "p": "filename",
                "v": "pizza.png",
                "vt": "str"
            },
            {
                "p": "filepath",
                "v": "c:\\Users\\4artu\\IdeaProjects\\node-red-nodes\\tutorial_images\\pizza.png",
